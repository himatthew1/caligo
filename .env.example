# ═══════════════════════════════════════════════════════════════
# CALIGO 환경변수 — 이 파일을 복사해 ".env" 로 만들고 값을 채우세요.
#   (.env 는 .gitignore 에 있어 git 에 안 올라갑니다 — 비밀키 안전)
#
# 값 위치: Supabase 대시보드 → Project Settings → API
# ═══════════════════════════════════════════════════════════════

# Project URL  (공개 OK)        예: https://xoxncrjlrfrnetyrbwcs.supabase.co
SUPABASE_URL=

# anon public 키 (공개 OK, 클라이언트로 전달됨)
SUPABASE_ANON_KEY=

# service_role 키 (🔒 비밀! 서버 전용 — 절대 외부 노출 금지)
SUPABASE_SERVICE_ROLE=
